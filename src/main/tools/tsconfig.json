{
  "compilerOptions": {
    "rootDir": "./",
    "allowJs": true,
    "target": "es2025",
    "lib": [
      "dom",
      "ES2025"
    ],
    "types": [
      "node",
      "showdown",
    ],
    "forceConsistentCasingInFileNames": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./out",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
  },
  "include": ["src/**/*",]
}
